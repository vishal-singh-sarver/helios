{
  "name": "helios",
  "version": "1.0.0",
  "description": "Professional Electron desktop application with integrated FastAPI backend",
  "author": "Navyug Designs",
  "homepage": "https://example.com",
  "main": "./out/main/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox",
    "dev:no-backend": "HELIOS_SKIP_BACKEND=1 electron-vite dev -- --no-sandbox",
    "build": "node scripts/sync-backend.js && electron-vite build",
    "preview": "electron-vite preview",
    "sync-backend": "node scripts/sync-backend.js",
    "package": "npm run build && electron-builder",
    "package:all": "npm run build && electron-builder -mwl --publish never",
    "package:mac": "npm run build && electron-builder --mac --publish never",
    "package:win": "npm run build && electron-builder --win --publish never",
    "package:linux": "npm run build && electron-builder --linux --publish never",
    "dist:clean": "rm -rf dist/ out/",
    "dist:clean-all": "rm -rf dist/ out/ node_modules/ package-lock.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate": "plop --plopfile internals/generators/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "e2e": "wdio run wdio.config.ts",
    "e2e:build": "npm run build && npm run e2e"
  },
  "dependencies": {
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@eslint/js": "^9.39.4",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.1.1",
    "@wdio/cli": "^9.27.0",
    "@wdio/globals": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "electron": "^33.4.11",
    "electron-builder": "^24.13.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "formik": "^2.4.9",
    "globals": "^17.4.0",
    "immer": "^10.0.3",
    "jsdom": "^29.0.1",
    "node-plop": "^0.26.3",
    "plop": "^3.1.2",
    "prettier": "^3.2.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "redux-saga": "^1.3.0",
    "reselect": "^5.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1",
    "wdio-electron-service": "^9.2.1"
  }
}
